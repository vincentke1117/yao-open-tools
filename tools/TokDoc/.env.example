# TokDoc Docker deployment settings

# Host port exposed by Docker. Visit http://127.0.0.1:18082/ on the server.
TOKDOC_HOST_PORT=18082

# Use 127.0.0.1 behind Nginx/Baota reverse proxy. Use 0.0.0.0 only for direct LAN access.
TOKDOC_BIND_ADDR=127.0.0.1

# Local persistent directories on the server.
TOKDOC_DATA_VOLUME=./data
TOKDOC_WATCH_VOLUME=./html-inbox

# Container paths. Keep these defaults unless you also change docker-compose.yml volumes.
TOKDOC_CONTAINER_WATCH_DIRS=/watch/html-inbox
TOKDOC_ALLOW_SOURCE_WRITE=false

# Optional runtime override for the admin console path. Leave empty to use database setting or /admin.
TOKDOC_ADMIN_PATH=

# Initial login for a fresh empty database only. Existing database settings are never overwritten.
TOKDOC_INITIAL_USERNAME=admin
TOKDOC_INITIAL_PASSWORD=tokdoc

# Image/container names. TOKDOC_IMAGE names the built image, or a pulled remote image when using --no-build.
TOKDOC_NODE_IMAGE=node:22-bookworm-slim
TOKDOC_IMAGE=tokdoc:latest
TOKDOC_CONTAINER_NAME=tokdoc
